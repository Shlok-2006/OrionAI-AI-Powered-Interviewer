datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum InterviewType {
  BEHAVIORAL
  TECHNICAL
  SYSTEM_DESIGN
  HR_CULTURE_FIT
}

enum SessionStatus {
  STARTED
  COMPLETED
}

enum Role {
  USER
  ASSISTANT
  SYSTEM
}

model User {
  id                String             @id @default(uuid())
  email             String             @unique
  password          String
  name              String
  jobRole           String
  experienceLevel   String             // e.g., "Junior", "Mid", "Senior"
  dob               String?
  userType          String?            // "student" | "professional"
  university        String?
  yearsOfExperience String?
  resumePath        String?
  sessions          InterviewSession[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model InterviewSession {
  id            String         @id @default(uuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  type          InterviewType
  status        SessionStatus  @default(STARTED)
  livekitRoom   String
  questionCount Int            @default(0)
  difficulty    String         @default("EASY")
  messages      Conversation[]
  feedback      Feedback?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Conversation {
  id         String           @id @default(uuid())
  sessionId  String
  session    InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role       Role
  content    String
  createdAt  DateTime         @default(now())
}

model Feedback {
  id                     String           @id @default(uuid())
  sessionId              String           @unique
  session                InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  overallScore           Int
  communicationScore     Int
  technicalScore     Int
  confidenceScore        Int
  leadershipScore        Int
  problemSolvingScore    Int
  strengths              Json             // Array of strings
  weaknesses             Json             // Array of strings
  suggestions            Json             // Array of strings
  overallSummary         String
  createdAt              DateTime         @default(now())
}
